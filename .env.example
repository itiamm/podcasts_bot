# Cloudflare R2
R2_ACCOUNT_ID=db941b74e7a1dd4dd7aab6d2f51bf930
R2_BUCKET_NAME=youtube-podcast-audio
R2_ENDPOINT=https://db941b74e7a1dd4dd7aab6d2f51bf930.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
PUBLIC_AUDIO_BASE_URL=https://pub-7ca9a55e10b3435a8ba74ad83cb7d936.r2.dev

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=5420198672

# Runtime
MP3_AUDIO_QUALITY=128K
MAX_VIDEO_SECONDS=10800
RETENTION_DAYS=30
MIN_LONG_VIDEO_SECONDS=181
PODCAST_DOWNLOAD_DIR=downloads
PODCAST_DB_PATH=data/podcasts.sqlite3
CONTENT_LOOKBACK_DAYS=7
BOOTSTRAP_SOURCE=rss
BOOTSTRAP_PLAYLIST_LIMIT=120

# AI providers
# Put the real key only in .env. Never commit it.
ASR_PROVIDER=local_whisper
TEXT_PROVIDER=ollama
TTS_PROVIDER=dashscope
TTS_FALLBACK_PROVIDER=macos_say
MACOS_TTS_VOICE=Tingting
MACOS_TTS_RATE=185
WHISPER_BIN=
WHISPER_MODEL_PATH=
WHISPER_LANGUAGE=en
WHISPER_EXTRA_ARGS=-bs 1 -bo 1
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_COMPATIBLE_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_ASR_MODEL=qwen3-asr-flash-filetrans
DASHSCOPE_TRANSLATE_MODEL=qwen-plus
DASHSCOPE_TTS_MODEL=sambert-zhide-v1
DASHSCOPE_TTS_FORMAT=wav
DASHSCOPE_TTS_SAMPLE_RATE=48000
DASHSCOPE_TTS_RATE=1.0
DASHSCOPE_WEBSOCKET_URL=
DASHSCOPE_TTS_VOICE=longxiaochun
DASHSCOPE_TTS_INSTRUCTIONS=轻松播客感，语速中等，表达自然清楚，适合财经内容收听。
DASHSCOPE_ASR_TIMEOUT_SECONDS=3600
DASHSCOPE_ASR_POLL_SECONDS=5
ZHIPU_API_KEY=
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.7-flash
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=minimaxai/minimax-m3
NVIDIA_MAX_TOKENS=8192
NVIDIA_TOP_P=0.95
NVIDIA_TIMEOUT_SECONDS=600
OLLAMA_API_BASE=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=4096
OLLAMA_TOP_P=0.9
OLLAMA_TIMEOUT_SECONDS=900
OLLAMA_KEEP_ALIVE=5m
TRANSLATE_CHUNK_CHARS=8000
CHINESE_PODCAST_TARGET_MINUTES=8-12
TTS_SEGMENT_CHARS=450

# Optional: use YouTube cookies if yt-dlp hits "Sign in to confirm you're not a bot".
# Examples:
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES=/absolute/path/to/youtube-cookies.txt
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_COOKIES=
YTDLP_JS_RUNTIMES=node
YTDLP_REMOTE_COMPONENTS=ejs:github
